{
  "name": "@aethercore/lattice-bridge",
  "version": "0.1.0",
  "description": "AetherCore Lattice Bridge Service",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm --filter @aethercore/shared build && pnpm run proto:types && tsc",
    "clean": "rm -rf dist",
    "proto:types": "node ./scripts/proto-types.mjs",
    "proto:update": "node ./scripts/proto-update.mjs",
    "start": "node dist/index.js",
    "dev": "pnpm run build && pnpm start",
    "test": "pnpm run build && node --test dist/__tests__/*.test.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "aethercore",
    "lattice",
    "bridge"
  ],
  "author": "AetherCore Team",
  "license": "MIT",
  "dependencies": {
    "@aethercore/shared": "workspace:*",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "hash-wasm": "^4.12.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.30",
    "typescript": "^5.3.3"
  }
}
