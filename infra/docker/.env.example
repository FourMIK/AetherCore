# AetherCore Docker Compose Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# AWS TESTBED CONFIGURATION (Optional)
# ============================================================================
# To connect to AWS AetherCore testbed network, uncomment and use:
# AWS_ALB_ENDPOINT=aethercore-aws-testbed-alb-1408772759.us-east-1.elb.amazonaws.com
# AWS_ALB_SCHEME=https
# AWS_REGION=us-east-1
# AETHER_BUNKER_ENDPOINT=aethercore-aws-testbed-alb-1408772759.us-east-1.elb.amazonaws.com:50051

# For local development, use the default Docker service names:
# AETHER_BUNKER_ENDPOINT=c2-router:50051

# ============================================================================
# PORT CONFIGURATION
# Customize these to avoid conflicts with other services or run multiple stacks
# ============================================================================

# C2 Router gRPC port (default: 50051)
C2_ROUTER_PORT=50051

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# Redis port (default: 6379)
REDIS_PORT=6379

# Gateway service port (default: 3000)
GATEWAY_PORT=3000

# Auth service port (default: 3001)
AUTH_PORT=3001

# Collaboration service port (default: 8080)
COLLABORATION_PORT=8080

# Lattice bridge service port (default: 3010)
LATTICE_BRIDGE_PORT=3010

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL database credentials (development only)
POSTGRES_DB=aethercore
POSTGRES_USER=aethercore
POSTGRES_PASSWORD=aethercore_dev_password

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT secret for auth service (CHANGE IN PRODUCTION)
JWT_SECRET=dev_jwt_secret_change_in_production

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Node environment
NODE_ENV=development

# ============================================================================
# LATTICE BRIDGE CONFIGURATION
# ============================================================================
# Example:
# LATTICE_BASE_URL=https://<environment_id>.env.sandboxes.developer.anduril.com
LATTICE_BASE_URL=
LATTICE_CLIENT_ID=
LATTICE_CLIENT_SECRET=
LATTICE_AGENT_ID=aethercore-agent
LATTICE_INTEGRATION_MODE=stealth_readonly
LATTICE_PROTOCOL_MODE=rest
LATTICE_INPUT_MODE=synthetic
LATTICE_SYNTHETIC_SCENARIO=sf_bay_maritime_incursion_v1
LATTICE_SYNTHETIC_SEED=AETHERCORE-STABLE-SEED-001
LATTICE_SYNTHETIC_TIMELINE=dual
LATTICE_SYNTHETIC_REPLAY_HOURS=24
# Synthetic ingest cadence override for demo pacing (milliseconds).
# Lower values accelerate synthetic event ingress without enabling outbound writes.
LATTICE_SYNTHETIC_INGEST_INTERVAL_MS=2000
LATTICE_SANDBOX_MODE=true
SANDBOXES_TOKEN=
LATTICE_GRPC_TARGET=lattice-grpc:443
LATTICE_GRPC_INSECURE=false
LATTICE_GRPC_CA_CERT_PATH=
LATTICE_GRPC_CLIENT_CERT_PATH=
LATTICE_GRPC_CLIENT_KEY_PATH=
LATTICE_GRPC_SERVER_NAME_OVERRIDE=
LATTICE_GRPC_POLL_WINDOW_MS=1500
LATTICE_GRPC_MAX_EVENTS=256
LATTICE_GATEWAY_INTERNAL_TOKEN=aethercore_local_lattice_internal_token
LATTICE_POLL_INTERVAL_MS=15000

# ============================================================================
# RUNNING MULTIPLE STACKS
# ============================================================================
# To run multiple stacks side-by-side:
# 1. Copy this file to .env-dev2 (or any name)
# 2. Change all port numbers to avoid conflicts
# 3. Run with: docker compose --env-file .env-dev2 -p aethercore-dev2 up
# ============================================================================
