{
  "name": "@aethercore/tablet-app",
  "version": "0.1.0",
  "description": "AetherCore Tactical Tablet Application - Standalone iOS/Android app",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:local": "eas build --local --platform android",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "dev": "expo start --clear",
    "eject": "expo eject"
  },
  "dependencies": {
    "@aethercore/shared": "workspace:*",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/stack": "^6.3.20",
    "expo": "^51.0.0",
    "expo-camera": "^14.1.1",
    "expo-device": "^6.0.2",
    "expo-file-system": "^16.0.8",
    "expo-font": "^12.0.9",
    "expo-location": "^17.0.1",
    "expo-sqlite": "^14.0.1",
    "expo-splash-screen": "^0.27.5",
    "expo-status-bar": "^1.12.1",
    "lucide-react-native": "^0.297.0",
    "react": "^18.2.0",
    "react-native": "^0.74.1",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-maps": "~1.18.0",
    "react-native-reanimated": "^3.8.1",
    "react-native-screens": "^3.29.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-web": "^0.19.10",
    "uuid": "^9.0.1",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.48",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "22.x"
  },
  "expo": {
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AetherCore to access your camera"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AetherCore to access your location"
        }
      ]
    ]
  }
}
