# AetherCore Dashboard Environment Configuration

# ============================================================================
# LOCAL DEVELOPMENT (default)
# ============================================================================
# Gateway API endpoint for REST calls
VITE_API_URL=http://localhost:3000

# Gateway WebSocket URL (use wss:// for production/AWS)
VITE_GATEWAY_URL=ws://localhost:3000

# (Optional) Collaboration WebSocket endpoint (Mission Guardian)
VITE_COLLABORATION_URL=ws://localhost:8080

# ============================================================================
# AWS AETHERCORE TESTBED NETWORK
# ============================================================================
# To connect to the AWS testbed, uncomment and use these values:
# VITE_API_URL=https://aethercore-aws-testbed-alb-1408772759.us-east-1.elb.amazonaws.com/api
# VITE_GATEWAY_URL=wss://aethercore-aws-testbed-alb-1408772759.us-east-1.elb.amazonaws.com
# VITE_COLLABORATION_URL=wss://aethercore-aws-testbed-alb-1408772759.us-east-1.elb.amazonaws.com:8080
# AETHER_BUNKER_ENDPOINT=aethercore-aws-testbed-alb-1408772759.us-east-1.elb.amazonaws.com:50051

# Production mode enforcement (requires hardware TPM)
# AETHERCORE_PRODUCTION=false

# Allow insecure localhost connections (false for production/AWS)
VITE_DEV_ALLOW_INSECURE_LOCALHOST=true

# TPM enforcement policy
TPM_ENABLED=false
